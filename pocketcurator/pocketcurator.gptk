# Pocket Curator gptokeyb config (ROCKNIX / default)
# Maps gamepad buttons to keyboard keys for pygame to consume.
#
#   A      -> Return     (flag toggle / confirm)
#   B      -> Escape     (back / cancel / quit on the exit prompt)
#   X      -> x          (delete: flagged games, or whole system on the carousel)
#   Y      -> y          (game list: jump-to-letter; carousel: Fetch from WebDAV)
#   L1     -> Page Up    (page up in game list)
#   R1     -> Page Down  (page down in game list)
#   L2     -> [          (description scroll up)
#   R2     -> ]          (description scroll down)
#   Start  -> Tab        (reserved)
#   Select -> F1         (open settings)
#   D-pad  -> arrow keys
#   Left stick -> arrow keys (so people with no d-pad can still navigate)
#
# Exit hotkey (Select+Start by default on most devices) is handled by
# gptokeyb itself via the device's mod_*.txt - we do not redefine it here.

back = f1
start = tab

a = enter
b = esc
x = x
y = y

l1 = pageup
r1 = pagedown
l2 = [
r2 = ]
l3 = f9

up = up
down = down
left = left
right = right

left_analog_up = up
left_analog_down = down
left_analog_left = left
left_analog_right = right
